{
  "name": "@kapsel/cli",
  "version": "0.2.0",
  "description": "CLI for scaffolding, building, and publishing Kapsel extensions",
  "type": "module",
  "bin": {
    "kapsel": "./dist/bin/kapsel.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@kapsel/sdk": "workspace:*",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "prompts": "^2.4.2",
    "fs-extra": "^11.2.0",
    "tar": "^7.0.0",
    "ajv": "^8.13.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/fs-extra": "^11.0.0",
    "@types/tar": "^6.1.0",
    "@types/prompts": "^2.4.0"
  },
  "files": ["dist", "README.md"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kapsel-Protocol/kapsel-core",
    "directory": "packages/cli"
  }
}
