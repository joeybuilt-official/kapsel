# Kapsel Registry — Environment Variables
# Copy to .env and fill in values before running.

# HTTP port to listen on
PORT=3000

# REQUIRED in production. Generate with: openssl rand -hex 32
KAPSEL_JWT_SECRET=change-me-in-production

# Public base URL of this registry (used in tarball download URLs)
KAPSEL_REGISTRY_URL=http://localhost:3000

# Display name returned by GET /health
KAPSEL_REGISTRY_NAME=my-kapsel-registry

# Path to SQLite database file (created automatically)
KAPSEL_DB_PATH=./data/registry.db

# Directory where uploaded tarballs are stored
KAPSEL_TARBALLS_DIR=./data/tarballs
