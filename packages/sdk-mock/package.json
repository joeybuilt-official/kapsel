{
  "name": "@kapsel/sdk-mock",
  "version": "0.2.0",
  "description": "In-memory mock host for testing Kapsel extensions locally",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@kapsel/sdk": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "files": ["dist", "README.md"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kapsel-Protocol/kapsel-core",
    "directory": "packages/sdk-mock"
  }
}
